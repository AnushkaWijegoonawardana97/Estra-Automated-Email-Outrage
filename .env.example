# MongoDB Atlas (database name defaults to "estra" if omitted from URI)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/estra
MONGODB_DB=estra

# Dashboard (dashboard/.env.local)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me
NEXT_PUBLIC_APP_URL=http://localhost:3000
CSC_API_KEY=

# Pipeline (pipeline/.env)
ANTHROPIC_API_KEY=sk-ant-...
BREVO_API_KEY=xkeysib-...
APP_URL=http://localhost:3000

# Optional: Brevo webhook secret for signature verification
BREVO_WEBHOOK_SECRET=

# Cloudinary (campaign media)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=campaign_unsigned
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=campaign_unsigned
